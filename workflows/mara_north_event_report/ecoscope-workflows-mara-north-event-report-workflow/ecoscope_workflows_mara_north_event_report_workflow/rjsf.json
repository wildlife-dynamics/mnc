  "$defs": {
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "EarthRangerConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EarthRangerConnection",
      "type": "object"
    },
    "SmoothingConfig": {
      "description": "Configuration for data smoothing.",
      "properties": {
        "method": {
          "const": "spline",
          "default": "spline",
          "description": "The smoothing method to apply. Currently supports 'spline'.",
          "enum": [
            "spline"
          ],
          "title": "Method",
          "type": "string"
        },
        "y_min": {
          "default": null,
          "description": "The minimum value to clamp smoothed values to. Useful for data like precipitation where values should not go below zero.",
          "ecoscope:advanced": true,
          "title": "Y Min",
          "type": "number"
        },
        "y_max": {
          "default": null,
          "description": "The maximum value to clamp smoothed values to.",
          "ecoscope:advanced": true,
          "title": "Y Max",
          "type": "number"
        },
        "resolution": {
          "default": 10,
          "description": "The resolution multiplier for interpolation points. The number of output points will be len(x) * resolution.",
          "ecoscope:advanced": true,
          "title": "Resolution",
          "type": "integer"
        },
        "degree": {
          "default": 3,
          "description": "The degree of the spline. 1: Linear, 2: Quadratic, 3: Cubic (recommended), 4-5: Higher degree.",
          "ecoscope:advanced": true,
          "title": "Degree",
          "type": "integer"
        }
      },
      "title": "SmoothingConfig",
      "type": "object"
    }
  },
