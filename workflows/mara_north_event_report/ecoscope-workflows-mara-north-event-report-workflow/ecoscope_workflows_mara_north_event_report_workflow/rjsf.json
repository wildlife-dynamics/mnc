        "format": {
          "default": "mixed",
          "title": "Format",
          "type": "string",
          "description": "            If `cast_to_datetime=True`, the format to pass to `pd.to_datetime`\n            when attempting to cast `time_col` to datetime. Defaults to \"mixed\".\n            ",
          "ecoscope:advanced": true
        }
      },
      "required": [],
