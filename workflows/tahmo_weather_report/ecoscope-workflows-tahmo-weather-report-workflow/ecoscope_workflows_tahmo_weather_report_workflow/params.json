{
  "properties": {
    "workflow_details": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "title": "Workflow Name",
          "type": "string"
        },
        "description": {
          "default": "",
          "title": "Workflow Description",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object",
      "description": "Add information that will help to differentiate this workflow from another.",
      "title": "Set workflow details"
    },
    "time_range": {
      "additionalProperties": false,
      "properties": {
        "since": {
          "format": "date-time",
          "title": "Since",
          "type": "string",
          "description": "The start time"
        },
        "until": {
          "format": "date-time",
          "title": "Until",
          "type": "string",
          "description": "The end time"
        },
        "timezone": {
          "allOf": [
            {
              "$ref": "#/$defs/TimezoneInfo"
            }
          ],
          "default": null,
          "title": "Timezone"
        },
        "time_format": {
          "default": "%d %b %Y %H:%M:%S",
          "title": "Time Format",
          "type": "string",
          "description": "The time format",
          "ecoscope:advanced": true
        }
      },
      "required": [
        "since",
        "until"
      ],
      "type": "object",
      "description": "Choose the period of time to analyze.",
      "title": "Time range"
    },
    "er_client_name": {
      "additionalProperties": false,
      "properties": {
        "data_source": {
          "$ref": "#/$defs/EarthRangerConnection",
          "title": "",
          "description": "Select one of your configured data sources."
        }
      },
      "required": [
        "data_source"
      ],
      "type": "object",
      "title": "Connect to ER"
    },
    "convert_chart_html_png": {
      "additionalProperties": false,
      "properties": {
        "config": {
          "allOf": [
            {
              "$ref": "#/$defs/ScreenshotConfig"
            }
          ],
          "default": {
            "width": 1280,
            "height": 720,
            "full_page": true,
            "device_scale_factor": 2.0,
            "wait_for_timeout": 30000,
            "timeout": 0,
            "max_concurrent_pages": 5
          },
          "title": "Config",
          "description": "The screenshot configuration"
        }
      },
      "required": [],
      "type": "object",
      "title": "Convert chart htmls to png"
    }
  },
  "$defs": {
    "TimezoneInfo": {
      "properties": {
        "label": {
          "title": "Label",
          "type": "string"
        },
        "tzCode": {
          "title": "Tzcode",
          "type": "string"
        },
        "name": {
          "title": "Name",
          "type": "string"
        },
        "utc": {
          "title": "Utc",
          "type": "string"
        }
      },
      "required": [
        "label",
        "tzCode",
        "name",
        "utc"
      ],
      "title": "TimezoneInfo",
      "type": "object"
    },
    "EarthRangerConnection": {
      "properties": {
        "name": {
          "title": "Data Source",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "title": "EarthRangerConnection",
      "type": "object"
    },
    "ScreenshotConfig": {
      "properties": {
        "width": {
          "default": 1280,
          "title": "Width",
          "type": "integer"
        },
        "height": {
          "default": 720,
          "title": "Height",
          "type": "integer"
        },
        "full_page": {
          "default": true,
          "title": "Full Page",
          "type": "boolean"
        },
        "device_scale_factor": {
          "default": 2.0,
          "title": "Device Scale Factor",
          "type": "number"
        },
        "wait_for_timeout": {
          "default": 30000,
          "description": "Forced wait time (ms) after network idle before taking the screenshot.",
          "title": "Wait For Timeout",
          "type": "integer"
        },
        "timeout": {
          "default": 0,
          "description": "Playwright navigation/screenshot timeout in ms. 0 disables timeouts.",
          "title": "Timeout",
          "type": "integer"
        },
        "max_concurrent_pages": {
          "default": 5,
          "description": "Maximum number of pages open at once when batching.",
          "title": "Max Concurrent Pages",
          "type": "integer"
        }
      },
      "title": "ScreenshotConfig",
      "type": "object"
    }
  },
  "uiSchema": {
    "workflow_details": {
      "ui:order": [
        "name",
        "description"
      ]
    },
    "time_range": {
      "ui:order": [
        "since",
        "until",
        "timezone",
        "time_format"
      ]
    },
    "ui:order": [
      "workflow_details",
      "time_range",
      "er_client_name",
      "convert_chart_html_png"
    ]
  },
  "additionalProperties": false
}
